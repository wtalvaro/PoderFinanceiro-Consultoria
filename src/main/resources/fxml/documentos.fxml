<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="br.com.poderfinanceiro.app.controller.DocumentoController">

    <ScrollPane fx:id="scrollPrincipal" fitToWidth="true" style="-fx-background-color: transparent;"
        styleClass="edge-to-edge">
        <content>
            <VBox spacing="15" style="-fx-padding: 20; -fx-background-color: white;">

                <Label text="📁 Documentação Digitalizada"
                    style="-fx-font-size: 18px; -fx-font-weight: bold;" />

                <StackPane>
                    <!-- Zona de Upload (Drag & Drop) -->
                    <VBox fx:id="dropZone" alignment="CENTER" spacing="10"
                        minHeight="160" prefHeight="160"
                        style="-fx-border-color: #aaaaaa; -fx-border-style: dashed; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-background-color: #fafafa; -fx-padding: 30; -fx-cursor: hand;"
                        onDragOver="#handleDragOver" onDragDropped="#handleDragDropped"
                        onMouseClicked="#handleFileSelection">

                        <Label text="📥 Arraste os documentos para cá"
                            style="-fx-font-size: 16px; -fx-text-fill: #555;" />
                        <Label text="ou clique para buscar no computador"
                            style="-fx-font-size: 12px; -fx-text-fill: #888;" />
                    </VBox>

                    <!-- Painel de Classificação Inline (Aparece após seleção do arquivo) -->
                    <VBox fx:id="panelClassificacao" alignment="CENTER" spacing="10" visible="false"
                        managed="false"
                        minHeight="160" prefHeight="160"
                        style="-fx-background-color: #e3f2fd; -fx-border-color: #90caf9; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 20;">

                        <Label fx:id="lblTituloPanel" text="Classifique o documento recebido:"
                            style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1565c0;" />
                        <Label fx:id="lblNomeArquivo"
                            style="-fx-text-fill: #555; -fx-font-style: italic;" />

                        <HBox spacing="10" alignment="CENTER">
                            <ComboBox fx:id="comboTipoDocumento" promptText="Selecione o tipo..."
                                prefWidth="250" />
                            <Button text="Confirmar" onAction="#confirmarUploadInline"
                                styleClass="accent"
                                style="-fx-font-weight: bold; -fx-background-color: #2e7d32; -fx-text-fill: white;" />
                            <Button text="Cancelar" onAction="#cancelarUploadInline"
                                styleClass="flat" />
                        </HBox>
                    </VBox>
                </StackPane>

                <!-- Tabela de Documentos -->
                <TableView fx:id="tableDocumentos" minHeight="300" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colTipo" text="Tipo de Documento" prefWidth="250" />
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="150" />
                        <TableColumn fx:id="colAcoes" text="Ações" prefWidth="150" />
                    </columns>
                    <placeholder>
                        <Label text="Nenhum documento anexado." />
                    </placeholder>
                </TableView>
            </VBox>
        </content>
    </ScrollPane>
</StackPane>