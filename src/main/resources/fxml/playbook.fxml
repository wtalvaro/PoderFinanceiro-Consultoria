<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="br.com.poderfinanceiro.app.controller.PlaybookController"
    style="-fx-background-color: white;">

    <VBox>
        <HBox spacing="10"
            style="-fx-padding: 10 15 10 15; -fx-background-color: #f1f3f5; -fx-border-color: #dee2e6; -fx-border-width: 0 0 1 0;"
            alignment="CENTER_LEFT">
            <Label text="🔍 Buscar Script:" style="-fx-font-weight: bold; -fx-text-fill: #495057;" />
            <TextField fx:id="txtBusca"
                promptText="Digite para filtrar por título, categoria ou conteúdo..."
                HBox.hgrow="ALWAYS" style="-fx-font-size: 14px;" />
        </HBox>

        <SplitPane dividerPositions="0.25" styleClass="classic" VBox.vgrow="ALWAYS">
            <items>
                <VBox>
                    <TreeView fx:id="treeViewScripts" showRoot="false" VBox.vgrow="ALWAYS" />
                    <HBox spacing="5" style="-fx-padding: 5;">
                        <Button text="➕ Novo Script" onAction="#handleNovo" HBox.hgrow="ALWAYS"
                            maxWidth="Infinity"
                            style="-fx-padding: 12; -fx-background-color: #e9ecef; -fx-font-weight: bold; -fx-font-size: 14px;" />
                        <Button text="🤖 Criar via IA" onAction="#handleGerarComIA"
                            style="-fx-padding: 12; -fx-background-color: #6c5ce7; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" />
                    </HBox>
                </VBox>

                <BorderPane style="-fx-background-color: #fafbfc; -fx-padding: 15;">
                    <top>
                        <HBox alignment="CENTER_LEFT" spacing="10"
                            style="-fx-padding: 0 0 15 0; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0; -fx-margin-bottom: 15;">
                            <VBox HBox.hgrow="ALWAYS" spacing="2">
                                <TextField fx:id="txtCategoria" editable="false"
                                    promptText="Categoria..."
                                    style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #6c757d; -fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0;" />
                                <TextField fx:id="txtTitulo" editable="false"
                                    promptText="Título do Script..."
                                    style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #212529; -fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0;" />
                            </VBox>
                            <HBox fx:id="boxAcoesTopo" spacing="5" alignment="CENTER">
                                <Button fx:id="btnEditar" text="✏️ Editar" onAction="#handleEditar"
                                    styleClass="flat" disable="true" />
                                <Button fx:id="btnExcluir" text="🗑️ Excluir"
                                    onAction="#handleExcluir" style="-fx-text-fill: #dc3545;"
                                    styleClass="flat" disable="true" />
                            </HBox>
                        </HBox>
                    </top>

                    <center>
                        <VBox style="-fx-padding: 15 0 15 0;">
                            <TextArea fx:id="txtConteudo" editable="false" wrapText="true"
                                VBox.vgrow="ALWAYS"
                                style="-fx-font-family: 'Segoe UI'; -fx-font-size: 16px; -fx-line-spacing: 6px; -fx-background-color: white; -fx-border-color: #ced4da; -fx-border-radius: 5;" />
                        </VBox>
                    </center>

                    <bottom>
                        <VBox spacing="15">
                            <HBox alignment="TOP_LEFT" spacing="10"
                                style="-fx-background-color: #fff3cd; -fx-border-color: #ffe69c; -fx-border-radius: 5; -fx-padding: 10;">
                                <Label text="💡 Dica de Ouro:"
                                    style="-fx-font-weight: bold; -fx-text-fill: #856404; -fx-padding: 2 0 0 0;"
                                    minWidth="-Infinity" />

                                <StackPane fx:id="stackDica" alignment="TOP_LEFT"
                                    HBox.hgrow="ALWAYS">
                                    <Label fx:id="lblDica" wrapText="true" maxWidth="Infinity"
                                        style="-fx-text-fill: #856404; -fx-font-size: 14px; -fx-font-style: italic; -fx-padding: 2 0 0 0;" />
                                    <TextArea fx:id="txtDica"
                                        visible="false"
                                        managed="false"
                                        wrapText="true"
                                        prefRowCount="2"
                                        prefHeight="65"
                                        maxHeight="80"
                                        promptText="Orientação técnica para este script..."
                                        style="-fx-background-color: transparent; -fx-control-inner-background: transparent; -fx-border-color: #ffe69c; -fx-border-radius: 4; -fx-text-fill: #856404; -fx-font-size: 14px; -fx-font-style: italic; -fx-padding: 5;" />
                                </StackPane>
                            </HBox>

                            <StackPane>
                                <Button fx:id="btnCopiar" maxWidth="Infinity"
                                    onAction="#handleCopiar" disable="true"
                                    style="-fx-background-color: #1976d2; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12; -fx-font-size: 15px; -fx-background-radius: 5;"
                                    text="📋 Copiar Script para o Clipboard" />
                                <HBox fx:id="boxAcoesEdicao" spacing="10" visible="false">
                                    <Button text="❌ Cancelar" onAction="#handleCancelar"
                                        maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                        style="-fx-padding: 12; -fx-background-color: #e9ecef; -fx-font-weight: bold; -fx-background-radius: 5;" />
                                    <Button text="💾 Salvar Modificações" onAction="#handleSalvar"
                                        maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                        style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 5;" />
                                </HBox>
                            </StackPane>
                        </VBox>
                    </bottom>
                </BorderPane>
            </items>
        </SplitPane>
    </VBox>

    <VBox fx:id="overlayIA" visible="false" alignment="CENTER"
        style="-fx-background-color: rgba(15, 23, 42, 0.65); -fx-padding: 30;">

        <VBox spacing="18" alignment="CENTER_LEFT" maxWidth="580" maxHeight="480" styleClass="card"
            style="-fx-background-color: #ffffff; -fx-padding: 28; -fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 25, 0, 0, 8);">
            <children>
                <HBox spacing="14" alignment="CENTER_LEFT">
                    <children>
                        <StackPane
                            style="-fx-background-color: #eef2ff; -fx-background-radius: 10; -fx-padding: 10;">
                            <children>
                                <Label text="✨" style="-fx-font-size: 20px;" />
                            </children>
                        </StackPane>
                        <VBox spacing="2">
                            <children>
                                <Label text="Engenharia Cognitiva de Scripts"
                                    style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-font-family: 'Segoe UI', system-ui;" />
                                <Label
                                    text="Cole o texto bruto recebido no grupo para estruturação automática."
                                    style="-fx-font-size: 12px; -fx-text-fill: #64748b; -fx-font-family: 'Segoe UI';" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <TextArea fx:id="txtInputIA"
                    promptText="Cole aqui a mensagem do grupo (copies, links e manuais misturados)..."
                    wrapText="true" VBox.vgrow="ALWAYS"
                    style="-fx-font-family: 'Segoe UI'; -fx-font-size: 14px; -fx-text-fill: #334155; -fx-background-color: #ffffff; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 6;" />

                <HBox spacing="12" alignment="BOTTOM_LEFT" style="-fx-padding: 4 0 0 0;">
                    <children>
                        <VBox spacing="4">
                            <children>
                                <Label text="Modelo de Inteligência"
                                    style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" />
                                <ComboBox fx:id="cmbModeloIA" prefWidth="180"
                                    style="-fx-background-color: #f1f5f9; -fx-background-radius: 6; -fx-border-color: #e2e8f0; -fx-border-radius: 6; -fx-font-size: 13px; -fx-cursor: hand;" />
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <Button text="Cancelar" onAction="#fecharOverlayIA" styleClass="flat"
                            minWidth="-Infinity"
                            style="-fx-padding: 10 22; -fx-font-weight: bold; -fx-text-fill: #64748b; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-size: 13px;" />

                        <Button fx:id="btnProcessarIA" text="✨ Estruturar com Gemini"
                            onAction="#processarTextoComIA" minWidth="-Infinity"
                            style="-fx-background-color: #4f46e5; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 10 22; -fx-cursor: hand; -fx-font-size: 13px; -fx-effect: dropshadow(three-pass-box, rgba(79, 70, 229, 0.25), 10, 0, 0, 4);" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </VBox>

</StackPane>