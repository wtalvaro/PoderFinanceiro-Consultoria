<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="br.com.poderfinanceiro.app.controller.PropostasListController">

    <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: -color-bg-subtle;">

        <HBox alignment="CENTER_LEFT" spacing="15">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="📄 Esteira de Crédito"
                    style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: -color-fg-default;" />
                <Label text="Monitoramento global de todas as propostas digitadas e em análise."
                    style="-fx-font-size: 14px; -fx-text-fill: -color-fg-muted;" />
            </VBox>
        </HBox>

        <Separator />

        <HBox spacing="15" alignment="CENTER_LEFT">
            <TextField fx:id="txtBusca"
                promptText="🔍 Pesquisar por cliente, CPF, banco ou status..."
                HBox.hgrow="ALWAYS"
                style="-fx-font-size: 14px; -fx-background-radius: 20; -fx-padding: 8 15;" />
            <Button text="🔄 Atualizar Esteira" onAction="#recarregarDados" styleClass="flat" />
        </HBox>

        <TableView fx:id="tablePropostas" VBox.vgrow="ALWAYS" styleClass="edge-to-edge">
            <columns>
                <TableColumn fx:id="colData" text="Data" prefWidth="100" />
                <TableColumn fx:id="colCliente" text="Paciente / Cliente" prefWidth="250" />
                <TableColumn fx:id="colBanco" text="Banco" prefWidth="150" />
                <TableColumn fx:id="colValor" text="Vlr. Solicitado" prefWidth="130"
                    style="-fx-alignment: CENTER-RIGHT;" />
                <TableColumn fx:id="colStatus" text="Status" prefWidth="150"
                    style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colAcoes" text="Ações" prefWidth="100"
                    style="-fx-alignment: CENTER;" />
            </columns>
            <placeholder>
                <VBox alignment="CENTER" spacing="10">
                    <Label text="A esteira está limpa. Nenhuma proposta em andamento."
                        style="-fx-text-fill: -color-fg-muted;" />
                </VBox>
            </placeholder>
        </TableView>

    </VBox>
</StackPane>