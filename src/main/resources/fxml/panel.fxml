<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" fitToHeight="true"
    maxHeight="1.7976931348623157E308"
    style="-fx-background-color: transparent;"
    styleClass="edge-to-edge" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
    minHeight="0"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="br.com.poderfinanceiro.app.controller.PanelController">

    <VBox fx:id="conteinerBotoes" spacing="5" prefWidth="70" alignment="TOP_CENTER"
        maxHeight="1.7976931348623157E308"
        style="-fx-background-color: -color-bg-default; -fx-padding: 15 5; -fx-border-color: -color-border-muted; -fx-border-width: 0 1 0 0;">

        <Button fx:id="btnDashboard" contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
            styleClass="flat, accent" onAction="#abrirWorkspace"
            style="-fx-cursor: hand; -fx-padding: 5 0;">
            <graphic>
                <Label text="📊" style="-fx-font-size: 22px;" />
            </graphic>
        </Button>

        <Separator style="-fx-padding: 5 0;" />

        <Button fx:id="btnPlaybook" contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
            styleClass="flat" onAction="#abrirPlaybook" style="-fx-cursor: hand; -fx-padding: 5 0;">
            <graphic>
                <Label text="📖" style="-fx-font-size: 22px;" />
            </graphic>
        </Button>

        <Button fx:id="btnBaseClientes" contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
            styleClass="flat" onAction="#abrirTelaBaseClientes"
            style="-fx-cursor: hand; -fx-padding: 5 0;">
            <graphic>
                <Label text="👥" style="-fx-font-size: 22px;" />
            </graphic>
        </Button>

        <Separator style="-fx-padding: 5 0;" />

        <Button fx:id="btnPropostas" contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
            styleClass="flat" onAction="#abrirPropostasList"
            style="-fx-cursor: hand; -fx-padding: 5 0;">
            <graphic>
                <Label text="📄" style="-fx-font-size: 22px;" />
            </graphic>
        </Button>

        <Button fx:id="btnPendencias" contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
            styleClass="flat" onAction="#abrirPendenciasList"
            style="-fx-cursor: hand; -fx-padding: 5 0;">
            <graphic>
                <Label text="⏳" style="-fx-font-size: 22px; -fx-text-fill: -color-danger-fg;" />
            </graphic>
        </Button>

        <Separator style="-fx-padding: 5 0;" />

        <Button fx:id="btnBancosConvenios" contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
            styleClass="flat" onAction="#abrirBancosConvenios"
            style="-fx-cursor: hand; -fx-padding: 5 0;">
            <graphic>
                <Label text="🏦" style="-fx-font-size: 22px;" />
            </graphic>
        </Button>

        <Button fx:id="btnTabelasJuros" contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
            styleClass="flat" onAction="#abrirTabelasJuros"
            style="-fx-cursor: hand; -fx-padding: 5 0;">
            <graphic>
                <Label text="📈" style="-fx-font-size: 22px;" />
            </graphic>
        </Button>

        <Button fx:id="btnTabelaComissoes" contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
            styleClass="flat" onAction="#abrirTabelaComissoes"
            style="-fx-cursor: hand; -fx-padding: 5 0;">
            <graphic>
                <Label text="💰" style="-fx-font-size: 22px;" />
            </graphic>
        </Button>

        <Button fx:id="btnLinks" contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity" styleClass="flat"
            onAction="#abrirLinksUteis" style="-fx-cursor: hand; -fx-padding: 5 0;">
            <graphic>
                <Label text="🔗" style="-fx-font-size: 22px;" />
            </graphic>
        </Button>

        <Region VBox.vgrow="ALWAYS" />
    </VBox>
</ScrollPane>