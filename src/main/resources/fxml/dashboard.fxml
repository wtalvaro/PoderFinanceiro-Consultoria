<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>

<VBox spacing="0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="br.com.poderfinanceiro.app.controller.DashboardController"
    style="-fx-background-color: -color-bg-subtle;">

    <HBox alignment="CENTER_LEFT" spacing="20"
        style="-fx-background-color: -color-bg-default; -fx-padding: 15 30; -fx-border-color: -color-border-muted; -fx-border-width: 0 0 1 0;">
        <VBox>
            <Label fx:id="lblNomeConsultor" styleClass="title-3" />
            <Label text="Poder Financeiro • Unidade Magé/RJ" styleClass="text-muted" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <VBox alignment="CENTER_RIGHT" spacing="2">
            <Label text="CICLO FINANCEIRO SEMANAL"
                style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: -color-warning-emphasis;" />
            <Label text="Fechamento na Quarta 23:59" style="-fx-font-weight: bold;" />
            <Label text="Liquidação na Sexta até 18h" styleClass="text-small" />
        </VBox>
    </HBox>

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
        <VBox spacing="25" style="-fx-padding: 30;">

            <HBox spacing="15">
                <VBox HBox.hgrow="ALWAYS"
                    style="-fx-background-color: -color-bg-default; -fx-padding: 15; -fx-border-radius: 8; -fx-border-color: -color-border-muted;">
                    <Label text="PROPOSTAS NA ESTEIRA" styleClass="text-caption" />
                    <Label fx:id="lblQtdAguardando" text="0" styleClass="title-2"
                        style="-fx-text-fill: -color-fg-muted;" />
                    <Label text="Aguardando banco ou doc" styleClass="text-small" />
                </VBox>

                <VBox HBox.hgrow="ALWAYS"
                    style="-fx-background-color: -color-bg-default; -fx-padding: 15; -fx-border-radius: 8; -fx-border-color: -color-border-muted;">
                    <Label text="PRODUÇÃO APROVADA" styleClass="text-caption" />
                    <Label fx:id="lblVolumeAprovado" text="R$ 0,00" styleClass="title-2"
                        style="-fx-text-fill: -color-fg-default;" />
                    <Label text="Volume global (mês/ano)" styleClass="text-small" />
                </VBox>

                <VBox HBox.hgrow="ALWAYS"
                    style="-fx-background-color: -color-bg-default; -fx-padding: 15; -fx-border-radius: 8; -fx-border-color: -color-accent-muted; -fx-border-width: 2;">
                    <Label text="EXPECTATIVA (A RECEBER)" styleClass="text-caption"
                        style="-fx-text-fill: -color-accent-emphasis; -fx-font-weight: bold;" />
                    <Label fx:id="lblComissaoPendente" text="R$ 0,00" styleClass="title-2"
                        style="-fx-text-fill: -color-accent-emphasis;" />
                    <Label text="Pendentes do ciclo atual e futuros" styleClass="text-small" />
                </VBox>

                <VBox HBox.hgrow="ALWAYS"
                    style="-fx-background-color: -color-bg-default; -fx-padding: 15; -fx-border-radius: 8; -fx-border-color: -color-success-muted; -fx-border-width: 2; -fx-background-color: -color-success-subtle;">
                    <Label text="COMISSÃO LIQUIDADA" styleClass="text-caption"
                        style="-fx-text-fill: -color-success-emphasis; -fx-font-weight: bold;" />
                    <Label fx:id="lblComissaoPaga" text="R$ 0,00" styleClass="title-2"
                        style="-fx-text-fill: -color-success-emphasis;" />
                    <Label text="Já repassado ao consultor" styleClass="text-small"
                        style="-fx-text-fill: -color-success-emphasis;" />
                </VBox>
            </HBox>

            <VBox
                style="-fx-background-color: -color-bg-default; -fx-border-radius: 10; -fx-border-color: -color-border-muted;"
                VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="15"
                    style="-fx-padding: 15; -fx-border-color: -color-border-muted; -fx-border-width: 0 0 1 0;">
                    <VBox spacing="2">
                        <Label text="Monitor de Propostas" styleClass="title-4" />
                        <Label text="Acompanhamento das financeiras" styleClass="text-small" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <TextField fx:id="txtBuscaPropostas" promptText="Buscar por Nome ou CPF..."
                        prefWidth="250" />
                    <Button text="Simular Novo" styleClass="flat" onAction="#simularNovo" />
                    <Button text="🔄 Atualizar Caixa" onAction="#carregarDadosReais"
                        styleClass="flat" />
                </HBox>

                <TableView fx:id="tabelaPropostas" VBox.vgrow="ALWAYS"
                    styleClass="striped, bordered" minHeight="400">
                    <columns>
                        <TableColumn fx:id="colCliente" text="Proponente" prefWidth="250" />
                        <TableColumn fx:id="colBanco" text="Banco" prefWidth="120" />
                        <TableColumn fx:id="colConvenio" text="Convênio" prefWidth="120" />
                        <TableColumn fx:id="colValorSolicitado" text="Vlr. Solicitado"
                            prefWidth="120" />
                        <TableColumn fx:id="colValor" text="Vlr. Aprovado" prefWidth="120"
                            style="-fx-font-weight: bold;" />
                        <TableColumn fx:id="colComissao" text="Comissão" prefWidth="100" />
                        <TableColumn fx:id="colStatus" text="Status Atual" prefWidth="130"
                            style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colAcoes" text="Ações" prefWidth="100" />
                    </columns>
                    <placeholder>
                        <Label text="Nenhuma proposta registrada no sistema." />
                    </placeholder>
                </TableView>

                <HBox spacing="20"
                    style="-fx-padding: 10 15; -fx-background-color: -color-bg-subtle;">
                    <HBox alignment="CENTER" spacing="5">
                        <Circle radius="4" style="-fx-fill: -color-warning-emphasis;" />
                        <Label text="Pendente / Digitada" styleClass="text-small" />
                    </HBox>
                    <HBox alignment="CENTER" spacing="5">
                        <Circle radius="4" style="-fx-fill: -color-success-emphasis;" />
                        <Label text="Aprovado Banco" styleClass="text-small" />
                    </HBox>
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>