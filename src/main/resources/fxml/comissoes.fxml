<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="br.com.poderfinanceiro.app.controller.ComissoesController">

    <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: -color-bg-subtle;">

        <HBox alignment="CENTER_LEFT" spacing="15">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="💰 Gestão de Repasses e Liquidação"
                    style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: -color-fg-default;" />
                <HBox spacing="5" alignment="CENTER_LEFT">
                    <Label text="Ciclo: Quarta (Banco) | "
                        style="-fx-font-size: 14px; -fx-text-fill: -color-fg-muted;" />
                    <Label text="Quinta (Verificação até 15h)"
                        style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: -color-danger-emphasis;" />
                    <Label text=" | Sexta (Pagamento)"
                        style="-fx-font-size: 14px; -fx-text-fill: -color-fg-muted;" />
                </HBox>
            </VBox>

            <HBox spacing="15">
                <VBox alignment="CENTER" styleClass="card">
                    <Label text="EXPECTATIVA (BANCO)"
                        style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: -color-warning-emphasis;" />
                    <Label fx:id="lblTotalPendente" text="R$ 0,00"
                        style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                </VBox>
                <VBox alignment="CENTER" styleClass="card">
                    <Label text="LIQUIDADO (CONSULTOR)"
                        style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: -color-success-emphasis;" />
                    <Label fx:id="lblTotalRecebido" text="R$ 0,00"
                        style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                </VBox>
            </HBox>
        </HBox>

        <Separator />

        <HBox spacing="15" alignment="CENTER_LEFT">
            <TextField fx:id="txtBusca" promptText="🔍 Pesquisar por proponente, banco ou status..."
                HBox.hgrow="ALWAYS" style="-fx-background-radius: 20; -fx-padding: 8 15;" />
            <Button text="🔄 Sincronizar" onAction="#recarregarDados" styleClass="flat" />
        </HBox>

        <TableView fx:id="tableComissoes" VBox.vgrow="ALWAYS" styleClass="striped">
            <columns>
                <TableColumn fx:id="colCliente" text="Proponente" prefWidth="220" />
                <TableColumn fx:id="colBanco" text="Banco" prefWidth="120" />

                <TableColumn fx:id="colValorBruto" text="Vlr. Bruto(R$)" prefWidth="110"
                    style="-fx-alignment: CENTER-RIGHT;" />
                <TableColumn fx:id="colVlrPago" text="Vlr. Pago Poder(R$)" prefWidth="120"
                    style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold;" />

                <TableColumn fx:id="colStatus" text="Status" prefWidth="130"
                    style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colRecebBanco" text="Receb. Banco (4ª feira)" prefWidth="140" />
                <TableColumn fx:id="colPrevisao" text="Previsão Pagto (6ª feira)" prefWidth="130" />
            </columns>
            <placeholder>
                <Label text="Nenhum registro de repasse para o ciclo atual." />
            </placeholder>
        </TableView>
    </VBox>

    <VBox fx:id="overlayAjuste" alignment="CENTER" visible="false"
        style="-fx-background-color: rgba(0, 0, 0, 0.6);">
        <VBox spacing="20" maxWidth="500"
            style="-fx-background-color: -color-bg-default; -fx-padding: 30; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 0);">

            <Label fx:id="lblTituloModal" text="Conciliação de Repasse" styleClass="title-3" />
            <Separator />

            <GridPane hgap="15" vgap="20">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="100" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="100" />
                </columnConstraints>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="1. Recebimento Banco (Quarta)" styleClass="text-caption" />
                    <DatePicker fx:id="dpRecebimentoBanco" maxWidth="Infinity" />
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="Status do Pagamento" styleClass="text-caption" />
                    <ComboBox fx:id="comboStatus" maxWidth="Infinity" />
                </VBox>

                <VBox spacing="8" GridPane.columnSpan="2" GridPane.rowIndex="1">
                    <Label text="⚠️ PRAZO LIMITE: Quinta-feira até as 15:00h"
                        style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: -color-danger-emphasis;" />

                    <HBox spacing="10" alignment="CENTER_LEFT"
                        style="-fx-padding: 10; -fx-background-color: -color-accent-subtle; -fx-background-radius: 5; -fx-border-color: -color-accent-muted;">
                        <CheckBox fx:id="cbVerificado"
                            text="CONFERIDO PELO CONSULTOR (Verificação de Quinta-feira)"
                            style="-fx-font-weight: bold; -fx-text-fill: -color-accent-emphasis;" />
                    </HBox>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="2">
                    <Label text="3. Previsão Pagto (Sexta)" styleClass="text-caption" />
                    <DatePicker fx:id="dpPrevisaoPagamento" maxWidth="Infinity" />
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="2">
                    <Label text="Valor Pago ao Consultor" styleClass="text-caption" />
                    <TextField fx:id="txtValorPagoPoder" promptText="R$ 0,00"
                        style="-fx-font-weight: bold;" />
                </VBox>

                <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnSpan="2"
                    GridPane.rowIndex="3"
                    style="-fx-padding: 10; -fx-background-color: -color-danger-subtle; -fx-background-radius: 5;">
                    <CheckBox fx:id="cbContestada"
                        text="⚠️ CONTESTAR VALORES (Divergência Identificada)"
                        style="-fx-text-fill: -color-danger-emphasis; -fx-font-weight: bold;" />
                </HBox>
            </GridPane>

            <HBox spacing="15" alignment="CENTER_RIGHT">
                <Button text="Cancelar" onAction="#fecharModal" styleClass="flat" />
                <Button text="💾 Salvar Conciliação" onAction="#salvarAjuste" styleClass="accent" />
            </HBox>
        </VBox>
    </VBox>
</StackPane>