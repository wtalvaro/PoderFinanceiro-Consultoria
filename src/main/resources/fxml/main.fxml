<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="rootStackPane" xmlns:fx="http://javafx.com/fxml"
       maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
       fx:controller="br.com.poderfinanceiro.app.presentation.controller.layout.MainController">

       <BorderPane fx:id="mainContainer" style="-fx-background-color: #ffffff;">

              <!-- ÁREA SUPERIOR -->
              <top>
                     <VBox fx:id="topBar">
                            <fx:include source="menu.fxml" />
                            <fx:include source="toolbar.fxml" />
                     </VBox>
              </top>

              <!-- ÁREA DE CONTEÚDO DINÂMICO -->
              <center>
                     <StackPane fx:id="contentArea" minHeight="0" />
              </center>

              <!-- BARRA DE STATUS -->
              <bottom>
                     <StackPane fx:id="bottomBar" maxWidth="1.7976931348623157E308">
                            <fx:include source="statusbar.fxml" />
                     </StackPane>
              </bottom>
       </BorderPane>

       <!-- OVERLAY DO CHAT IA (LATERAL) -->
       <HBox fx:id="overlayChatIA" visible="false" alignment="CENTER_RIGHT"
              style="-fx-background-color: transparent;">
              <Region fx:id="dragHandleChat"
                     prefWidth="6.0" minWidth="6.0" maxWidth="6.0"
                     style="-fx-cursor: h-resize; -fx-background-color: rgba(0,0,0,0.03);" />
              <fx:include fx:id="painelChat" source="ajuda_chat.fxml" />
       </HBox>

       <!-- OVERLAY DE LOGOUT -->
       <VBox fx:id="overlaySair" alignment="CENTER" spacing="20" visible="false"
              style="-fx-background-color: rgba(0, 0, 0, 0.4); -fx-padding: 50;">
              <VBox alignment="CENTER" spacing="20" maxWidth="400" maxHeight="-Infinity"
                     style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 0);">
                     <Label text="🚪 Encerrar Sessão"
                            style="-fx-font-size: 20px; -fx-font-weight: bold;" />
                     <Label
                            text="Deseja realmente sair do sistema? Alterações não salvas serão perdidas."
                            wrapText="true" textAlignment="CENTER" />
                     <HBox spacing="15" alignment="CENTER">
                            <Button text="Cancelar" onAction="#cancelarLogout" styleClass="flat" />
                            <Button text="Sair Agora" onAction="#confirmarLogout"
                                   styleClass="danger" />
                     </HBox>
              </VBox>
       </VBox>

       <!-- OVERLAY DE LOADING (BLOQUEANTE) -->
       <VBox fx:id="overlayLoading" visible="false" alignment="CENTER"
              style="-fx-background-color: rgba(255, 255, 255, 0.7);">
              <VBox alignment="CENTER" spacing="15" maxWidth="250" maxHeight="-Infinity"
                     style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 15, 0, 0, 0);">
                     <ProgressIndicator style="-fx-progress-color: -color-accent-fg;" />
                     <Label fx:id="lblLoadingTexto"
                            wrapText="true"
                            textAlignment="CENTER"
                            style="-fx-font-size: 14px; -fx-text-fill: -color-fg-default;" />
              </VBox>
       </VBox>

       <!-- CORREÇÃO: OVERLAY DE MENSAGEM (ALTURA DINÂMICA) -->
       <VBox fx:id="overlayMensagem" visible="false" alignment="CENTER"
              style="-fx-background-color: rgba(0, 0, 0, 0.4); -fx-padding: 50;">

              <VBox alignment="CENTER" minHeight="200" maxWidth="450" maxHeight="-Infinity"
                     style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 0);">

                     <Label fx:id="lblMsgTitulo" alignment="CENTER" textAlignment="CENTER"
                            style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-padding: 0 0 10 0;" />

                     <ScrollPane fitToWidth="true" fitToHeight="true"
                            style="-fx-background-color: transparent; -fx-background: transparent;"
                            hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" maxHeight="400">
                            <content>
                                   <StackPane alignment="CENTER">
                                          <Label fx:id="lblMsgTexto" wrapText="true"
                                                 textAlignment="CENTER" alignment="CENTER"
                                                 style="-fx-font-size: 14px; -fx-text-fill: #475569; -fx-padding: 0 0 15 0;" />
                                   </StackPane>
                            </content>
                     </ScrollPane>

                     <Button text="Entendido" onAction="#ocultarOverlayMensagem" maxWidth="Infinity"
                            style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
              </VBox>
       </VBox>

       <!-- OVERLAY DE CONFIRMAÇÃO GLOBAL -->
       <VBox fx:id="overlayConfirmacaoGlobal" visible="false" alignment="CENTER"
              style="-fx-background-color: rgba(0, 0, 0, 0.4); -fx-padding: 50;">

              <VBox alignment="CENTER" spacing="20" maxWidth="400" maxHeight="-Infinity"
                     style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 0);">

                     <Label fx:id="lblConfirmacaoTitulo"
                            style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                     <Label fx:id="lblConfirmacaoTexto" wrapText="true" textAlignment="CENTER"
                            style="-fx-font-size: 14px; -fx-text-fill: #475569;" />

                     <HBox spacing="15" alignment="CENTER">
                            <Button text="Cancelar" onAction="#cancelarConfirmacaoGlobal"
                                   styleClass="flat" />
                            <Button fx:id="btnConfirmarGlobal" onAction="#executarConfirmacaoGlobal"
                                   style="-fx-font-weight: bold; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;" />
                     </HBox>
              </VBox>
       </VBox>
</StackPane>