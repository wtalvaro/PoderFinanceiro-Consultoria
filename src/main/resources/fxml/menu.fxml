<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>

<MenuBar xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="br.com.poderfinanceiro.app.presentation.controller.layout.MenuController">

    <Menu text="_Poder Financeiro">
        <MenuItem text="📊 Visão Geral" onAction="#handleDashboard" accelerator="Shortcut+D" />
        <SeparatorMenuItem />
        <MenuItem text="🚪 Encerrar Sessão (Logout)" onAction="#handleLogout" />
        <MenuItem text="❌ Sair do Sistema" onAction="#handleSair" />
    </Menu>

    <Menu text="_Operacional">
        <MenuItem text="✨ Copiloto de Vendas" onAction="#handleAbrirCopiloto"
            accelerator="Shortcut+Space" />
        <SeparatorMenuItem />
        <MenuItem text="👤 Novo Contato" onAction="#handleNovoContato" accelerator="Shortcut+N" />
        <MenuItem text="👥 Gestão de Clientes" onAction="#handleClientes" accelerator="Shortcut+G" />
        <MenuItem text="📄 Esteira de Propostas" onAction="#handlePropostas"
            accelerator="Shortcut+P" />
    </Menu>

    <Menu text="_Financeiro">
        <MenuItem text="💰 Gestão de Comissões (RV)" onAction="#handleComissoes"
            accelerator="Shortcut+F" />
    </Menu>

    <Menu text="P_arâmetros">
        <MenuItem text="🏦 Bancos &amp; Convênios" onAction="#handleBancos" accelerator="Shortcut+B" />
        <MenuItem text="📈 Tabelas de Juros" onAction="#handleJuros" accelerator="Shortcut+J" />
    </Menu>

    <Menu text="F_erramentas">
        <MenuItem text="📥 Importador de Tabelas (IA)" onAction="#handleImportarTabelas" />
        <MenuItem text="📚 Playbook de Vendas" onAction="#handlePlaybook" />
        <MenuItem text="🔗 Links Úteis" onAction="#handleLinks" accelerator="Shortcut+L" />
        <SeparatorMenuItem />
        <MenuItem text="🔄 Limpar Cache de Telas" onAction="#handleLimparCache" disable="true" />
    </Menu>

    <Menu text="_Ajuda">
        <MenuItem text="🤖 Assistente de IA (Gemini)" onAction="#handleAbrirIA"
            accelerator="Shortcut+I" />
        <SeparatorMenuItem />
        <MenuItem
            text="🔄 Verificar Atualizações..."
            onAction="#handleVerificarAtualizacoes" />
    </Menu>
</MenuBar>