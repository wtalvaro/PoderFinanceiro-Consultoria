<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="br.com.poderfinanceiro.app.presentation.controller.proposta.PropostaController">

    <BorderPane>
        <top>
            <ToolBar
                style="-fx-background-color: -color-bg-default; -fx-padding: 8 15; -fx-border-color: -color-border-muted; -fx-border-width: 0 0 1 0;">
                <items>
                    <Button fx:id="btnSalvar" text="💾 Salvar Proposta" onAction="#salvarProposta"
                        styleClass="flat, accent" style="-fx-font-weight: bold;">
                        <tooltip>
                            <Tooltip text="Salvar alterações da proposta" />
                        </tooltip>
                    </Button>

                    <Separator orientation="VERTICAL" />

                    <HBox alignment="CENTER" spacing="8"
                        style="-fx-background-color: #e8f5e9; -fx-padding: 4 12; -fx-background-radius: 6; -fx-border-color: #c8e6c9; -fx-border-radius: 6;">
                        <Label fx:id="lblTituloComissao" text="Comissão Estimada:"
                            style="-fx-font-weight: bold; -fx-text-fill: #2e7d32; -fx-font-size: 12px;" />
                        <Label fx:id="lblComissaoEstimada" text="R$ 0,00"
                            style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1b5e20;" />
                    </HBox>

                    <Region HBox.hgrow="ALWAYS" />

                    <Button fx:id="btnRemover" text="🗑️ Remover" onAction="#removerProposta"
                        styleClass="flat, danger" style="-fx-font-weight: bold;">
                        <tooltip>
                            <Tooltip text="Excluir permanentemente esta proposta" />
                        </tooltip>
                    </Button>
                    <Button fx:id="btnFechar" text="✖ Fechar" onAction="#fecharProposta"
                        styleClass="flat, warning" style="-fx-font-weight: bold;">
                        <tooltip>
                            <Tooltip text="Fechar proposta e retornar à lista" />
                        </tooltip>
                    </Button>
                </items>
            </ToolBar>
        </top>

        <center>
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                <VBox spacing="25" style="-fx-padding: 30;">

                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Label text="📄 Nova Simulação / Proposta"
                            style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: -color-fg-default;" />
                    </HBox>

                    <Separator />

                    <VBox spacing="5"
                        style="-fx-background-color: -color-bg-default; -fx-padding: 20; -fx-border-radius: 8; -fx-border-color: -color-border-muted;">
                        <Label text="👤 Cliente Vinculado"
                            style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: -color-fg-muted;" />
                        <ComboBox fx:id="cbCliente" maxWidth="Infinity"
                            promptText="Selecione ou busque o cliente..." />
                    </VBox>

                    <VBox spacing="15"
                        style="-fx-background-color: -color-bg-default; -fx-padding: 20; -fx-border-radius: 8; -fx-border-color: -color-border-muted;">
                        <Label text="1. Dados da Solicitação"
                            style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: -color-fg-muted;" />

                        <GridPane hgap="20" vgap="15">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="100" />
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="100" />
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="100" />
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="100" />
                            </columnConstraints>

                            <VBox spacing="5" GridPane.columnIndex="0">
                                <Label text="Tipo de Convênio" style="-fx-font-weight: bold;" />
                                <ComboBox fx:id="cbConvenio" maxWidth="Infinity"
                                    promptText="Ex: INSS, FGTS..." />
                            </VBox>

                            <VBox spacing="5" GridPane.columnIndex="1">
                                <Label text="Valor Solicitado (R$)" style="-fx-font-weight: bold;" />
                                <TextField fx:id="txtValorSolicitado" promptText="0,00" />
                            </VBox>

                            <VBox spacing="5" GridPane.columnIndex="2">
                                <Label text="Prazo Desejado" style="-fx-font-weight: bold;" />
                                <Spinner fx:id="spinPrazoDesejado" maxWidth="Infinity" />
                            </VBox>

                            <VBox spacing="5" GridPane.columnIndex="3">
                                <Label text="Status Atual" />
                                <ComboBox fx:id="cbStatus" maxWidth="Infinity" />
                            </VBox>
                        </GridPane>
                    </VBox>

                    <VBox spacing="15"
                        style="-fx-background-color: -color-bg-default; -fx-padding: 20; -fx-border-radius: 8; -fx-border-color: -color-border-muted;">
                        <Label text="2. Instituição e Produto"
                            style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: -color-fg-muted;" />

                        <GridPane hgap="20" vgap="15">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="100" />
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="100" />
                            </columnConstraints>

                            <VBox spacing="5" GridPane.columnIndex="0">
                                <Label text="Banco Parceiro" />
                                <ComboBox fx:id="cbBanco" maxWidth="Infinity"
                                    promptText="Selecione o banco..." />
                            </VBox>

                            <VBox spacing="5" GridPane.columnIndex="1">
                                <Label text="Tabela / Regra de Juros" />
                                <ComboBox fx:id="cbTabela" maxWidth="Infinity"
                                    promptText="Selecione a tabela..." />
                            </VBox>
                        </GridPane>
                    </VBox>

                    <VBox spacing="15"
                        style="-fx-background-color: -color-bg-default; -fx-padding: 20; -fx-border-radius: 8; -fx-border-color: -color-border-muted;">
                        <Label text="3. Condições Finais"
                            style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: -color-fg-muted;" />

                        <GridPane hgap="20" vgap="15">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="100" />
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="100" />
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="100" />
                            </columnConstraints>

                            <VBox spacing="5" GridPane.columnIndex="0">
                                <Label text="Valor Aprovado (R$)"
                                    style="-fx-font-weight: bold; -fx-text-fill: -color-accent-emphasis;" />
                                <TextField fx:id="txtValorAprovado" promptText="0,00" />
                                <Label text="* Base real para comissão"
                                    style="-fx-font-size: 11px; -fx-text-fill: -color-fg-muted;" />
                            </VBox>

                            <VBox spacing="5" GridPane.columnIndex="1">
                                <Label text="Prazo (Meses)" />
                                <Spinner fx:id="spinPrazo" maxWidth="Infinity" />
                            </VBox>

                            <VBox spacing="5" GridPane.columnIndex="2">
                                <Label text="Valor da Parcela (R$)" />
                                <TextField fx:id="txtParcela" promptText="0,00" />

                                <Label fx:id="lblTotalPago" text="Total a Pagar: R$ 0,00"
                                    style="-fx-text-fill: #555555; -fx-font-size: 11px; -fx-font-style: italic; -fx-font-weight: bold;" />
                            </VBox>

                        </GridPane>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Observações / Anamnese da Negociação"
                            style="-fx-font-weight: bold;" />
                        <TextArea fx:id="txtObservacoes" prefRowCount="3"
                            promptText="Ex: Cliente prefere pagar no dia 10. Documento RG está um pouco rasgado..."
                            wrapText="true" />
                    </VBox>

                    <VBox spacing="10" styleClass="card">
                        <VBox spacing="14" alignment="CENTER_LEFT" style="-fx-max-width: Infinity;">

                            <HBox spacing="12" alignment="CENTER_LEFT"
                                style="-fx-background-color: #f8f9fa; -fx-background-radius: 8; -fx-padding: 10 16; -fx-border-color: #e9ecef; -fx-border-width: 1; -fx-border-radius: 8;">
                                <children>
                                    <Label text="🤖 Motor de Análise Cognitiva:"
                                        style="-fx-font-weight: bold; -fx-text-fill: #495057; -fx-font-size: 13px;" />
                                    <ComboBox fx:id="cmbModeloIA" prefWidth="220"
                                        style="-fx-background-radius: 6; -fx-background-color: #ffffff; -fx-border-color: #ced4da; -fx-border-radius: 6; -fx-font-size: 13px; -fx-cursor: hand;" />
                                </children>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 6 0 2 0;">
                                <children>
                                    <Label text="📂 Documentação da Proposta"
                                        style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #212529;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button fx:id="btnAnexarDocumento" text="➕ Anexar Documento"
                                        onAction="#anexarDocumento"
                                        styleClass="flat accent"
                                        style="-fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 6; -fx-cursor: hand;" />
                                </children>
                            </HBox>

                        </VBox>

                        <TableView fx:id="tableDocumentos" prefHeight="150">
                            <columns>
                                <TableColumn fx:id="colTipoDocumento" text="Tipo de Exame"
                                    prefWidth="150" />
                                <TableColumn fx:id="colDataUpload" text="Data de Upload"
                                    prefWidth="120" />
                                <TableColumn fx:id="colAcoes" text="Ações" prefWidth="100" />
                            </columns>
                        </TableView>
                    </VBox>

                </VBox>
            </ScrollPane>
        </center>
    </BorderPane>

    <VBox fx:id="overlayDocumento" visible="false" alignment="CENTER"
        style="-fx-background-color: rgba(0, 0, 0, 0.6); -fx-padding: 50;">

        <VBox spacing="20" alignment="CENTER" maxWidth="450" styleClass="card"
            style="-fx-background-color: -color-bg-default; -fx-padding: 30; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 20, 0, 0, 0);">

            <Label fx:id="lblOverlayDocTitulo" text="Anexar Novo Documento"
                style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -color-fg-default;" />

            <VBox spacing="5" style="-fx-alignment: CENTER_LEFT; -fx-pref-width: 100%;">
                <Label text="Tipo / Nome do Documento:"
                    style="-fx-font-weight: bold; -fx-text-fill: -color-fg-muted;" />
                <ComboBox fx:id="cbTipoDocumentoOverlay" editable="true" maxWidth="Infinity"
                    promptText="Ex: RG Frente, Comprovante de Residência..." />
            </VBox>

            <VBox fx:id="boxSelecaoArquivo" spacing="10" alignment="CENTER"
                style="-fx-pref-width: 100%; -fx-padding: 15; -fx-border-color: #ced4da; -fx-border-radius: 8; -fx-border-style: dashed;">
                <Button text="📂 Procurar Arquivo no Computador..."
                    onAction="#procurarArquivo" styleClass="flat" />
                <Label fx:id="lblArquivoSelecionado" text="Nenhum arquivo selecionado"
                    style="-fx-text-fill: -color-fg-muted; -fx-font-size: 12px;" wrapText="true"
                    textAlignment="CENTER" />
            </VBox>

            <HBox spacing="15" alignment="CENTER" style="-fx-padding: 15 0 0 0;">
                <Button text="Cancelar" onAction="#fecharOverlayDocumento" styleClass="flat" />
                <Button fx:id="btnSalvarDocumento" text="💾 Salvar Documento"
                    onAction="#confirmarSalvarDocumento"
                    styleClass="accent" style="-fx-font-weight: bold;" disable="true" />
            </HBox>
        </VBox>
    </VBox>

</StackPane>