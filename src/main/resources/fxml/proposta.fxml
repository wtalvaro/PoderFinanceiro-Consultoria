<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="br.com.poderfinanceiro.app.controller.PropostaController">

    <ScrollPane fitToWidth="true" xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1" style="-fx-background-color: transparent;">

        <VBox spacing="25" style="-fx-padding: 30;">

            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label text="📄 Nova Simulação / Proposta"
                    style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: -color-fg-default;" />
                <Region HBox.hgrow="ALWAYS" />

                <VBox alignment="CENTER"
                    style="-fx-background-color: #e8f5e9; -fx-padding: 10 20; -fx-border-radius: 8; -fx-border-color: #c8e6c9;">
                    <Label fx:id="lblTituloComissao" text="Comissão Estimada"
                        style="-fx-font-weight: bold;" />
                    <Label fx:id="lblComissaoEstimada" text="R$ 0,00"
                        style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1b5e20;" />
                </VBox>
            </HBox>

            <Separator />

            <VBox spacing="15"
                style="-fx-background-color: -color-bg-default; -fx-padding: 20; -fx-border-radius: 8; -fx-border-color: -color-border-muted;">
                <Label text="1. Triagem Inicial (Filtro Inteligente)"
                    style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: -color-fg-muted;" />

                <GridPane hgap="20" vgap="15">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="100" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="100" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="100" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="100" />
                    </columnConstraints>

                    <VBox spacing="5" GridPane.columnIndex="0">
                        <Label text="Tipo de Convênio" style="-fx-font-weight: bold;" />
                        <ComboBox fx:id="cbConvenio" maxWidth="Infinity"
                            promptText="Ex: INSS, FGTS..." />
                    </VBox>

                    <VBox spacing="5" GridPane.columnIndex="1">
                        <Label text="Valor Solicitado (R$)" style="-fx-font-weight: bold;" />
                        <TextField fx:id="txtValorSolicitado" promptText="0,00" />
                    </VBox>

                    <VBox spacing="5" GridPane.columnIndex="2">
                        <Label text="Prazo Desejado" style="-fx-font-weight: bold;" />
                        <Spinner fx:id="spinPrazoDesejado" maxWidth="Infinity" />
                    </VBox>

                    <VBox spacing="5" GridPane.columnIndex="3">
                        <Label text="Status Atual" />
                        <ComboBox fx:id="cbStatus" maxWidth="Infinity" />
                    </VBox>
                </GridPane>
            </VBox>

            <VBox spacing="15"
                style="-fx-background-color: -color-bg-default; -fx-padding: 20; -fx-border-radius: 8; -fx-border-color: -color-border-muted;">
                <Label text="2. Instituição e Produto Disponível"
                    style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: -color-fg-muted;" />

                <GridPane hgap="20" vgap="15">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="100" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="100" />
                    </columnConstraints>

                    <VBox spacing="5" GridPane.columnIndex="0">
                        <Label text="Banco Parceiro" />
                        <ComboBox fx:id="cbBanco" maxWidth="Infinity"
                            promptText="Aguardando triagem..." />
                    </VBox>

                    <VBox spacing="5" GridPane.columnIndex="1">
                        <Label text="Tabela / Regra de Juros" />
                        <ComboBox fx:id="cbTabela" maxWidth="Infinity"
                            promptText="Aguardando banco..." />
                    </VBox>
                </GridPane>
            </VBox>

            <VBox spacing="15"
                style="-fx-background-color: -color-bg-default; -fx-padding: 20; -fx-border-radius: 8; -fx-border-color: -color-border-muted;">
                <Label text="3. Condições Finais"
                    style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: -color-fg-muted;" />

                <GridPane hgap="20" vgap="15">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="100" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="100" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="100" />
                    </columnConstraints>

                    <VBox spacing="5" GridPane.columnIndex="0">
                        <Label text="Valor Aprovado (R$)"
                            style="-fx-font-weight: bold; -fx-text-fill: -color-accent-emphasis;" />
                        <TextField fx:id="txtValorAprovado" promptText="0,00" />
                        <Label text="* Base real para comissão"
                            style="-fx-font-size: 11px; -fx-text-fill: -color-fg-muted;" />
                    </VBox>

                    <VBox spacing="5" GridPane.columnIndex="1">
                        <Label text="Prazo (Meses)" />
                        <Spinner fx:id="spinPrazo" maxWidth="Infinity" />
                    </VBox>

                    <VBox spacing="5" GridPane.columnIndex="2">
                        <Label text="Valor da Parcela (R$)" />
                        <TextField fx:id="txtParcela" promptText="0,00" />

                        <Label fx:id="lblTotalPago" text="Total a Pagar: R$ 0,00"
                            style="-fx-text-fill: #555555; -fx-font-size: 11px; -fx-font-style: italic; -fx-font-weight: bold;" />
                    </VBox>

                </GridPane>
            </VBox>

            <VBox spacing="5">
                <Label text="Observações / Anamnese da Negociação" style="-fx-font-weight: bold;" />
                <TextArea fx:id="txtObservacoes" prefRowCount="3"
                    promptText="Ex: Cliente prefere pagar no dia 10. Documento RG está um pouco rasgado..."
                    wrapText="true" />
            </VBox>

            <VBox spacing="10" styleClass="card">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="📂 Documentação da Proposta" style="-fx-font-weight: bold;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button fx:id="btnAnexarDocumento" text="➕ Anexar Documento"
                        onAction="#handleAnexarDocumento" styleClass="flat, accent" />
                </HBox>

                <TableView fx:id="tableDocumentos" prefHeight="150">
                    <columns>
                        <TableColumn fx:id="colTipoDocumento" text="Tipo de Exame" prefWidth="150" />
                        <TableColumn fx:id="colDataUpload" text="Data de Upload" prefWidth="120" />
                        <TableColumn fx:id="colAcoes" text="Ações" prefWidth="100" />
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </ScrollPane>

    <VBox fx:id="overlayExclusao" visible="false" alignment="CENTER"
        style="-fx-background-color: rgba(0, 0, 0, 0.4); -fx-padding: 20;">

        <VBox spacing="20" alignment="CENTER" maxWidth="400" maxHeight="200"
            styleClass="card"
            style="-fx-background-color: -color-bg-default; -fx-padding: 30; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 0);">

            <Label text="🗑️ Excluir Documento"
                style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -color-danger-fg;" />

            <Label fx:id="lblConfirmacaoExclusao"
                text="Tem certeza que deseja remover este documento da proposta?"
                wrapText="true" textAlignment="CENTER" style="-fx-font-size: 14px;" />

            <HBox spacing="15" alignment="CENTER">
                <Button text="Cancelar" onAction="#cancelarExclusao" styleClass="flat" />
                <Button text="Sim, Excluir" onAction="#confirmarExclusao" styleClass="danger" />
            </HBox>
        </VBox>
    </VBox>

</StackPane>