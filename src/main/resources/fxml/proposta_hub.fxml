<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="br.com.poderfinanceiro.app.controller.PropostaHubController">

    <SplitPane dividerPositions="0.3" xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1" >

        <VBox spacing="10" style="-fx-padding: 10; -fx-background-color: -color-bg-default;">
            <Label text="Histórico de Simulações"
                style="-fx-font-weight: bold; -fx-font-size: 14px;" />

            <Button text="➕ Nova Simulação" maxWidth="Infinity" styleClass="accent"
                onAction="#criarNovaSimulacao" />

            <ListView fx:id="listPropostas" VBox.vgrow="ALWAYS" />

            <Button fx:id="btnRemover" text="🗑️ Remover Simulação" onAction="#solicitarRemocao"
                maxWidth="Infinity"
                style="-fx-text-fill: #c62828; -fx-font-weight: bold; -fx-background-color: transparent; -fx-border-color: #c62828; -fx-border-radius: 4; -fx-cursor: hand;">
                <tooltip>
                    <Tooltip text="Excluir permanentemente a simulação selecionada" />
                </tooltip>
            </Button>
        </VBox>

        <StackPane fx:id="containerDetalhes">
        </StackPane>
    </SplitPane>

    <VBox fx:id="overlayConfirmacao" visible="false" alignment="CENTER"
        style="-fx-background-color: rgba(0, 0, 0, 0.6); -fx-padding: 50;">
        <VBox alignment="CENTER" spacing="20" maxWidth="400"
            style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 20, 0, 0, 0);">

            <Label text="⚠️ Alterações Não Salvas"
                style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #c62828;" />

            <Label fx:id="lblConfirmacaoTexto" wrapText="true" textAlignment="CENTER"
                style="-fx-font-size: 14px; -fx-text-fill: #333;" />

            <HBox spacing="15" alignment="CENTER" style="-fx-padding: 20 0 0 0;">
                <Button text="Cancelar" onAction="#cancelarAcao" styleClass="flat" />
                <Button text="Descartar" onAction="#confirmarDescarte"
                    style="-fx-background-color: #c62828; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4;" />
            </HBox>
        </VBox>
    </VBox>

</StackPane>