<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="br.com.poderfinanceiro.app.presentation.controller.atendimento.ProponenteController">

    <ScrollPane fx:id="scrollPrincipal" fitToWidth="true" fitToHeight="true"
        style="-fx-background-color: transparent;" styleClass="edge-to-edge">
        <content>
            <VBox spacing="20" style="-fx-background-color: #ffffff; -fx-padding: 30;">

                <VBox spacing="5">
                    <Label fx:id="lblTituloTela" text="Cadastrar Novo Contato"
                        style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: -color-fg-default;" />
                    <Label
                        text="Preencha o que tiver disponível. Conforme a conversa evoluir, você pode voltar e editar."
                        style="-fx-font-size: 13px; -fx-text-fill: -color-fg-muted;" />
                </VBox>

                <Label fx:id="lblMensagem" visible="false" managed="false" wrapText="true" />

                <Label text="1. Contato Inicial (Obrigatório)"
                    style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: -color-accent-fg;" />
                <Separator />

                <GridPane hgap="15" vgap="15">
                    <columnConstraints>
                        <ColumnConstraints minWidth="130" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200" maxWidth="400" />
                    </columnConstraints>

                    <Label text="Nome Completo: *" GridPane.columnIndex="0" GridPane.rowIndex="0"
                        style="-fx-font-weight: bold;" />
                    <TextField fx:id="txtNome" promptText="Ex: João da Silva"
                        GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <Label text="CPF:" GridPane.columnIndex="0" GridPane.rowIndex="1"
                        style="-fx-font-weight: bold;" />
                    <TextField fx:id="txtCpf" promptText="000.000.000-00" GridPane.columnIndex="1"
                        GridPane.rowIndex="1" />

                    <Label text="WhatsApp:" GridPane.columnIndex="0" GridPane.rowIndex="2"
                        style="-fx-font-weight: bold;" />
                    <TextField fx:id="txtTelefone" promptText="(00) 00000-0000"
                        GridPane.columnIndex="1" GridPane.rowIndex="2" />

                    <Label text="Origem:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <ComboBox fx:id="cbOrigem" promptText="Onde o cliente te achou?"
                        maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                    <Label text="Classificação:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                    <ComboBox fx:id="cbClassificacao"
                        promptText="Como você classifica este contato?" maxWidth="Infinity"
                        GridPane.columnIndex="1" GridPane.rowIndex="4" />
                </GridPane>

                <VBox spacing="10" style="-fx-padding: 20 0 0 0;">
                    <Label text="2. Perfil Operacional"
                        style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: -color-accent-fg;" />
                    <Separator />

                    <GridPane hgap="15" vgap="15">
                        <columnConstraints>
                            <ColumnConstraints minWidth="130" />
                            <ColumnConstraints hgrow="ALWAYS" minWidth="200" maxWidth="400" />
                        </columnConstraints>

                        <Label text="Data de Nascimento:" GridPane.columnIndex="0"
                            GridPane.rowIndex="0" />
                        <DatePicker fx:id="dpDataNascimento" promptText="DD/MM/AAAA"
                            maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <Label text="Tipo de Vínculo:" GridPane.columnIndex="0"
                            GridPane.rowIndex="2" />
                        <ComboBox fx:id="cbVinculo" promptText="Ex: Aposentado, Pensionista..."
                            maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label text="Matrícula/Benefício:" GridPane.columnIndex="0"
                            GridPane.rowIndex="3" />
                        <TextField fx:id="txtMatricula" promptText="Número do benefício"
                            GridPane.columnIndex="1" GridPane.rowIndex="3" />

                        <Label text="Renda Mensal (R$):" GridPane.columnIndex="0"
                            GridPane.rowIndex="4" />
                        <TextField fx:id="txtRenda" promptText="0,00" GridPane.columnIndex="1"
                            GridPane.rowIndex="4" />
                    </GridPane>
                </VBox>

                <ProgressIndicator fx:id="progress" visible="false" managed="false" prefHeight="30"
                    prefWidth="30" />
            </VBox>
        </content>
    </ScrollPane>

</StackPane>