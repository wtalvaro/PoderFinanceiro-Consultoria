<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="br.com.poderfinanceiro.app.controller.AtendimentoHubController">
    <BorderPane style="-fx-background-color: #f4f4f4;">

        <!-- TOPO FIXO -->
        <top>
            <ToolBar
                style="-fx-background-color: -color-bg-default; -fx-padding: 8 15; -fx-border-color: -color-border-muted; -fx-border-width: 0 0 1 0;">
                <items>
                    <Button text="💬 WhatsApp" onAction="#abrirWhatsappRapido" styleClass="flat"
                        style="-fx-font-weight: bold;">
                        <tooltip>
                            <Tooltip text="Abrir Conversa no WhatsApp" />
                        </tooltip>
                    </Button>


                    <Button text="📋 Gerar Resumo" onAction="#copiarResumoLead" styleClass="flat"
                        style="-fx-font-weight: bold;">
                        <tooltip>
                            <Tooltip text="Copiar Resumo para Área de Transferência" />
                        </tooltip>
                    </Button>

                    <Pane HBox.hgrow="ALWAYS" /> <!-- Empurra as ações principais para a direita -->

                    <Separator orientation="VERTICAL" />

                    <!-- Ações de Fechamento (Mantendo o destaque no Salvar) -->
                    <Button fx:id="btnSalvar" text="💾 Salvar Alterações"
                        onAction="#handleSalvar"
                        styleClass="accent"
                        style="-fx-font-weight: bold; -fx-background-color: -color-accent-fg; -fx-text-fill: white;">
                        <tooltip>
                            <Tooltip text="Salvar Informações" />
                        </tooltip>
                    </Button>
                </items>
            </ToolBar>
        </top>

        <center>
            <TabPane fx:id="subTabPane" side="LEFT" tabClosingPolicy="UNAVAILABLE"
                tabMinWidth="30" tabMaxWidth="150" xmlns:fx="http://javafx.com/fxml/1">
                <tabs>
                    <Tab text="📝 Dados">
                        <fx:include fx:id="abaLead" source="lead.fxml" />
                    </Tab>

                    <Tab text="📍 Localização">
                        <fx:include fx:id="abaEndereco" source="endereco.fxml" />
                    </Tab>

                    <Tab text="📄 Proposta / Simulação">
                        <fx:include fx:id="abaPropostaHub" source="proposta_hub.fxml" />
                    </Tab>

                    <Tab text="🔗 Links Úteis">
                        <fx:include fx:id="abaLinks" source="links_uteis.fxml" />
                    </Tab>
                </tabs>
            </TabPane>
        </center>
    </BorderPane>

    <!-- NOVO: Overlay de Confirmação de Saída -->
    <VBox fx:id="overlayConfirmacaoSaida" alignment="CENTER" spacing="20" visible="false"
        style="-fx-background-color: rgba(0, 0, 0, 0.6); -fx-padding: 50;">
        <VBox alignment="CENTER" spacing="20" maxWidth="450"
            style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 20, 0, 0, 0);">

            <Label text="⚠️ Alterações Não Salvas"
                style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #c62828;" />

            <Label text="Você possui alterações na Lead atual. Deseja salvar antes de sair?"
                wrapText="true" textAlignment="CENTER"
                style="-fx-font-size: 14px; -fx-text-fill: #333;" />

            <HBox spacing="15" alignment="CENTER" style="-fx-padding: 20 0 0 0;">
                <Button text="Cancelar" onAction="#cancelarSaida" styleClass="flat" />
                <Button text="Descartar Alterações" onAction="#descartarESair"
                    style="-fx-background-color: #f5f5f5; -fx-text-fill: #666; -fx-border-color: #ddd; -fx-border-radius: 4; -fx-background-radius: 4;" />
                <Button text="Salvar e Sair" onAction="#descartarESair"
                    styleClass="accent"
                    style="-fx-font-weight: bold; -fx-background-color: -color-accent-fg; -fx-text-fill: white;" />
            </HBox>
        </VBox>
    </VBox>


    <!-- NOVO: Overlay de Preview do Relatório Profissional -->
    <VBox fx:id="overlayResumo" alignment="CENTER" spacing="20" visible="false"
        style="-fx-background-color: rgba(0, 0, 0, 0.5); -fx-padding: 50;">
        <VBox alignment="TOP_LEFT" spacing="20" maxWidth="600" maxHeight="700"
            style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 20, 0, 0, 0);">

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="📋 Revisão do Relatório de Qualificação"
                    style="-fx-font-size: 18px; -fx-font-weight: bold;" />
            </HBox>

            <Separator />

            <ScrollPane fitToWidth="true"
                style="-fx-background-color: transparent; -fx-background: #f9f9f9; -fx-padding: 10;">
                <!-- Usamos um Label com fonte monoespaçada para simular como ficará no WhatsApp -->
                <Label fx:id="lblResumoPreview" wrapText="true"
                    style="-fx-font-family: 'Monospaced'; -fx-font-size: 13px; -fx-text-fill: #333;" />
            </ScrollPane>

            <HBox spacing="15" alignment="CENTER_RIGHT">
                <Button text="Cancelar" onAction="#fecharOverlayResumo" styleClass="flat" />
                <Button text="Confirmar e Copiar" onAction="#confirmarCopiaResumo"
                    styleClass="accent" style="-fx-padding: 8 20; -fx-font-weight: bold;" />
            </HBox>
        </VBox>
    </VBox>

    <VBox fx:id="overlayMensagem" visible="false" alignment="CENTER"
        style="-fx-background-color: rgba(0, 0, 0, 0.5); -fx-padding: 50;">

        <VBox alignment="CENTER" spacing="20" maxWidth="400"
            style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 20, 0, 0, 0);">

            <Label fx:id="lblMensagemTitulo" text="Aviso"
                style="-fx-font-size: 18px; -fx-font-weight: bold;" />

            <Label fx:id="lblMensagemTexto" wrapText="true" textAlignment="CENTER"
                style="-fx-font-size: 14px; -fx-text-fill: #333;" />

            <Button text="Entendido" onAction="#esconderMensagem"
                styleClass="accent"
                style="-fx-padding: 8 30; -fx-font-weight: bold; -fx-cursor: hand;" />
        </VBox>
    </VBox>
</StackPane>