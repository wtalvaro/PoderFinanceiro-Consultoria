<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<StackPane fx:id="rootPane" style="-fx-background-color: white;"
    xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="br.com.poderfinanceiro.app.controller.CadastroController">
    <children>
        <VBox alignment="CENTER" maxWidth="600.0" spacing="25.0"
            style="-fx-background-color: white; -fx-padding: 40;">
            <children>

                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label text="👤" style="-fx-font-size: 50;" />
                        <Label styleClass="title-2" text="Novo Consultor"
                            style="-fx-font-weight: bold; -fx-font-size: 22;" />
                        <Text fill="#727272" text="Crie sua conta local no Poder Financeiro" />
                    </children>
                </VBox>

                <HBox spacing="20.0" alignment="TOP_CENTER">
                    <VBox spacing="12.0" HBox.hgrow="ALWAYS">
                        <VBox spacing="5.0">
                            <Label text="Nome Completo" />
                            <TextField fx:id="txtNome" prefHeight="35.0" />
                        </VBox>
                        <VBox spacing="5.0">
                            <Label text="E-mail" />
                            <TextField fx:id="txtEmail" prefHeight="35.0" />
                        </VBox>
                        <VBox spacing="5.0">
                            <Label text="Nome de Usuário (Login)" />
                            <TextField fx:id="txtUsername" prefHeight="35.0"
                                promptText="ex: user.financeiro" />
                        </VBox>
                    </VBox>

                    <VBox spacing="12.0" HBox.hgrow="ALWAYS">
                        <VBox spacing="5.0">
                            <Label text="Senha" />
                            <PasswordField fx:id="txtSenha" prefHeight="35.0" />
                        </VBox>
                        <VBox spacing="5.0">
                            <Label text="Confirmar Senha" />
                            <PasswordField fx:id="txtConfirmarSenha" prefHeight="35.0" />
                        </VBox>
                    </VBox>
                </HBox>

                <VBox spacing="6.0">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="5">
                            <Label text="Chave de API do Gemini"
                                style="-fx-font-weight: bold; -fx-font-size: 13px;" />
                            <Label text="(Obrigatório)"
                                style="-fx-font-size: 11px; -fx-text-fill: #999999; -fx-font-style: italic;" />
                        </HBox>
                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                            <children>
                                <PasswordField fx:id="txtGeminiApiKey" prefHeight="40.0"
                                    HBox.hgrow="ALWAYS"
                                    promptText="Cole sua chave AIzaSy... aqui"
                                    style="-fx-background-radius: 6; -fx-padding: 10;" />
                                <Button fx:id="btnGerarChave" onAction="#abrirGoogleAIStudio"
                                    text="🌐 Obter Chave"
                                    style="-fx-background-color: #0D47A1; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"
                                    prefHeight="40.0" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Button fx:id="btnCadastrar" maxWidth="Infinity" onAction="#handleCadastrar"
                            prefHeight="40.0" styleClass="accent" text="Finalizar Cadastro" />
                        <Label fx:id="lblMensagem" styleClass="danger" visible="false"
                            wrapText="true" />
                        <Separator prefWidth="200.0" />
                        <Button onAction="#handleVoltarLogin" styleClass="flat"
                            text="Já tem conta? Voltar ao Login" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</StackPane>