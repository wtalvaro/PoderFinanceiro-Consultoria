<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>

<VBox prefWidth="450"
    style="-fx-background-color: #efeae2; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 0 1;"
    xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="br.com.poderfinanceiro.app.presentation.controller.suporte.AjudaChatController">

    <HBox alignment="CENTER_LEFT"
        style="-fx-background-color: #FFFFFF; -fx-padding: 12 20; -fx-border-color: #EEEEEE; -fx-border-width: 0 0 1 0;">
        <VBox spacing="2">
            <Label text="Poder Financeiro Gemini IA"
                style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #212121; -fx-font-family: 'Segoe UI', sans-serif;" />
            <Label text="● Analista Especialista Ativo"
                style="-fx-font-size: 13px; -fx-text-fill: #1B5E20; -fx-font-weight: bold;" />
        </VBox>
        <Pane HBox.hgrow="ALWAYS" />

        <Button text="🧿" onAction="#toggleSidebarChats"
            style="-fx-background-color: transparent; -fx-font-size: 20px; -fx-cursor: hand; -fx-padding: 2 10;">
            <tooltip>
                <Tooltip text="Histórico de Conversas" />
            </tooltip>
        </Button>

        <Button text="🔑" onAction="#toggleConfigChave"
            style="-fx-background-color: transparent; -fx-font-size: 20px; -fx-cursor: hand; -fx-padding: 2 10;">
            <tooltip>
                <Tooltip text="Configurar Chave API" />
            </tooltip>
        </Button>

        <Button text="✕" onAction="#fecharPainel"
            style="-fx-background-color: transparent; -fx-font-size: 20px; -fx-cursor: hand; -fx-text-fill: #9E9E9E;" />
    </HBox>

    <VBox fx:id="paneConfigChave" visible="false" managed="false" spacing="12"
        style="-fx-background-color: #FFFFFF; -fx-padding: 14 16; -fx-border-color: #EEEEEE; -fx-border-width: 0 0 1 0;">
        <VBox spacing="4">
            <Label text="Atualizar Chave de API do Gemini"
                style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #616161;" />
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <PasswordField fx:id="txtNovaApiKey"
                    promptText="Cole a nova chave AIzaSy... aqui" HBox.hgrow="ALWAYS"
                    style="-fx-background-radius: 6; -fx-background-color: #F1F3F4; -fx-padding: 8 12;" />
                <Button text="Salvar" onAction="#salvarNovaChave"
                    style="-fx-background-color: #00a884; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 8 14;" />
            </HBox>
            <HBox alignment="CENTER_RIGHT">
                <Hyperlink text="🌐 Gerar nova chave no Google AI Studio"
                    onAction="#abrirGoogleAIStudioChat"
                    style="-fx-font-size: 11px; -fx-text-fill: #0D47A1; -fx-underline: true;" />
            </HBox>
        </VBox>
    </VBox>

    <HBox alignment="CENTER_LEFT" spacing="10"
        style="-fx-background-color: #f8f9fa; -fx-padding: 8 20; -fx-border-color: #EEEEEE; -fx-border-width: 0 0 1 0;">
        <Label text="✨ Modelo:"
            style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #616161;" />
        <ComboBox fx:id="cmbModelo" prefWidth="220"
            style="-fx-background-color: #FFFFFF; -fx-background-radius: 15; -fx-border-color: #E0E0E0; -fx-border-radius: 15; -fx-font-size: 12px; -fx-cursor: hand;" />
        <Region HBox.hgrow="ALWAYS" />
        <Label text="2.5+"
            style="-fx-background-color: #e8f5e9; -fx-text-fill: #2e7d32; -fx-font-size: 10px; -fx-padding: 2 8; -fx-background-radius: 10; -fx-font-weight: bold;" />
    </HBox>

    <StackPane VBox.vgrow="ALWAYS" alignment="TOP_RIGHT">

        <WebView fx:id="webViewChat" />

        <HBox fx:id="overlaySidebar" visible="false" managed="false">
            <Pane HBox.hgrow="ALWAYS" onMouseClicked="#toggleSidebarChats" style="-fx-cursor: hand;" />

            <VBox fx:id="paneSidebarChats" prefWidth="385"
                style="-fx-background-color: #f8f9fa; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 0 1; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 15, 0, -5, 0);">
                <VBox style="-fx-padding: 15;">
                    <Button text="➕ Nova Conversa" onAction="#iniciarNovaConversa"
                        maxWidth="Infinity"
                        style="-fx-background-color: #00a884; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 8; -fx-cursor: hand;" />
                </VBox>
                <Label text="Recentes"
                    style="-fx-padding: 0 15 5 15; -fx-font-weight: bold; -fx-text-fill: #9e9e9e; -fx-font-size: 12px; -fx-text-transform: uppercase;" />
                <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-padding: 0;" VBox.vgrow="ALWAYS">
                    <VBox fx:id="listaChatsRecentes" spacing="5" style="-fx-padding: 5 10 10 10;" />
                </ScrollPane>
            </VBox>
        </HBox>
    </StackPane>

    <HBox fx:id="boxAnexo" alignment="CENTER_LEFT" spacing="8" visible="false" managed="false"
        style="-fx-background-color: #E3F2FD; -fx-padding: 6 16; -fx-border-color: #BBDEFB; -fx-border-width: 1 0 0 0;">
        <Label text="📎" style="-fx-font-size: 14px; -fx-text-fill: #1565C0;" />
        <Label fx:id="lblNomeFicheiro" text="ficheiro.pdf"
            style="-fx-font-size: 12px; -fx-text-fill: #1565C0; -fx-font-weight: bold;"
            HBox.hgrow="ALWAYS" />
        <Button text="✕" onAction="#removerAnexo"
            style="-fx-background-color: transparent; -fx-cursor: hand; -fx-text-fill: #D32F2F;" />
    </HBox>

    <VBox
        style="-fx-background-color: #F0F2F5; -fx-padding: 14 16; -fx-border-color: #DDDDDD; -fx-border-width: 1 0 0 0;">
        <HBox spacing="10" alignment="CENTER">

            <Button text="📎" onAction="#escolherFicheiro"
                style="-fx-background-color: transparent; -fx-font-size: 20px; -fx-cursor: hand; -fx-text-fill: #616161;" />

            <TextField fx:id="txtMensagem" promptText="Digite sua dúvida ou anexe um documento..."
                HBox.hgrow="ALWAYS" onAction="#enviarMensagem"
                style="-fx-background-color: #FFFFFF; -fx-background-radius: 22; -fx-padding: 12 18; -fx-font-size: 15px;" />

            <Button text="➤" onAction="#enviarMensagem"
                style="-fx-background-color: #00a884; -fx-text-fill: white; -fx-background-radius: 22; -fx-min-width: 44; -fx-min-height: 44; -fx-cursor: hand; -fx-font-size: 16px;" />
        </HBox>
    </VBox>
</VBox>