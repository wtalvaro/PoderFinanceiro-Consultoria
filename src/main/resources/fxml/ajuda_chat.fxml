<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>

<VBox prefWidth="450"
    style="-fx-background-color: #efeae2; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 0 1;"
    xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="br.com.poderfinanceiro.app.controller.AjudaChatController">

    <HBox alignment="CENTER_LEFT"
        style="-fx-background-color: #FFFFFF; -fx-padding: 12 20; -fx-border-color: #EEEEEE; -fx-border-width: 0 0 1 0;">
        <VBox spacing="2">
            <Label text="Poder Financeiro Gemini IA"
                style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #212121; -fx-font-family: 'Segoe UI', 'Helvetica Neue', sans-serif;" />
            <Label text="● Analista Especialista Ativo"
                style="-fx-font-size: 13px; -fx-text-fill: #1B5E20; -fx-font-weight: bold; -fx-font-family: 'Segoe UI', sans-serif;" />
        </VBox>
        <Pane HBox.hgrow="ALWAYS" />

        <Button text="🔑" onAction="#toggleConfigChave"
            style="-fx-background-color: transparent; -fx-font-size: 22px; -fx-cursor: hand; -fx-padding: 2 8; -fx-background-radius: 50%;">
            <tooltip>
                <Tooltip text="Configurar Chave de API do Gemini" style="-fx-font-size: 12px;" />
            </tooltip>
        </Button>

        <Button text="✕" onAction="#fecharPainel"
            style="-fx-background-color: transparent; -fx-font-size: 22px; -fx-cursor: hand; -fx-text-fill: #9E9E9E; -fx-font-weight: bold; -fx-padding: 2 8; -fx-background-radius: 50%;" />
    </HBox>

    <VBox fx:id="paneConfigChave" visible="false" managed="false" spacing="12"
        style="-fx-background-color: #FFFFFF; -fx-padding: 14 16; -fx-border-color: #EEEEEE; -fx-border-width: 0 0 1 0;">
        <children>
            <VBox spacing="4">
                <Label text="Selecionar Modelo de Inteligência Artificial"
                    style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #616161;" />
                <ComboBox fx:id="cmbModelo" maxWidth="Infinity"
                    style="-fx-background-color: #F1F3F4; -fx-background-radius: 6; -fx-padding: 2; -fx-font-size: 13px;" />
            </VBox>

            <Separator style="-fx-opacity: 0.5;" />

            <VBox spacing="4">
                <Label text="Atualizar Chave de API do Gemini"
                    style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #616161;" />
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <PasswordField fx:id="txtNovaApiKey"
                            promptText="Cole a nova chave AIzaSy... aqui" HBox.hgrow="ALWAYS"
                            style="-fx-background-radius: 6; -fx-background-color: #F1F3F4; -fx-padding: 8 12; -fx-font-size: 13px;" />
                        <Button text="Salvar" onAction="#salvarNovaChave"
                            style="-fx-background-color: #00a884; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 8 14; -fx-font-size: 13px;" />
                    </children>
                </HBox>
                <HBox alignment="CENTER_RIGHT">
                    <Hyperlink text="🌐 Gerar nova chave no Google AI Studio"
                        onAction="#abrirGoogleAIStudioChat"
                        style="-fx-font-size: 11px; -fx-text-fill: #0D47A1; -fx-underline: true; -fx-padding: 2 0 0 0;" />
                </HBox>
            </VBox>
        </children>
    </VBox>

    <WebView fx:id="webViewChat" VBox.vgrow="ALWAYS" />

    <HBox fx:id="boxAnexo" alignment="CENTER_LEFT" spacing="8" visible="false" managed="false"
        style="-fx-background-color: #E3F2FD; -fx-padding: 6 16; -fx-border-color: #BBDEFB; -fx-border-width: 1 0 0 0;">
        <Label text="📎" style="-fx-font-size: 14px; -fx-text-fill: #1565C0;" />
        <Label fx:id="lblNomeFicheiro" text="ficheiro.pdf"
            style="-fx-font-size: 12px; -fx-text-fill: #1565C0; -fx-font-weight: bold;"
            HBox.hgrow="ALWAYS" />
        <Button text="✕" onAction="#removerAnexo"
            style="-fx-background-color: transparent; -fx-cursor: hand; -fx-text-fill: #D32F2F; -fx-padding: 0 4;" />
    </HBox>

    <VBox
        style="-fx-background-color: #F0F2F5; -fx-padding: 14 16; -fx-border-color: #DDDDDD; -fx-border-width: 1 0 0 0;">
        <HBox spacing="10" alignment="CENTER">
            <Button text="📎" onAction="#escolherFicheiro"
                style="-fx-background-color: transparent; -fx-font-size: 20px; -fx-cursor: hand; -fx-text-fill: #616161; -fx-padding: 4;" />

            <TextField fx:id="txtMensagem" promptText="Digite sua dúvida ou anexe um holerite..."
                HBox.hgrow="ALWAYS" onAction="#enviarMensagem"
                style="-fx-background-color: #FFFFFF; -fx-background-radius: 22; -fx-padding: 12 18; -fx-font-size: 15px; -fx-text-fill: #000000; -fx-font-family: 'Segoe UI', sans-serif;" />

            <Button text="➤" onAction="#enviarMensagem"
                style="-fx-background-color: #00a884; -fx-text-fill: white; -fx-background-radius: 22; -fx-min-width: 44; -fx-min-height: 44; -fx-max-width: 44; -fx-max-height: 44; -fx-font-size: 16px; -fx-cursor: hand;" />
        </HBox>
    </VBox>
</VBox>