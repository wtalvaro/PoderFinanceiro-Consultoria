<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefWidth="410"
    style="-fx-background-color: #efeae2; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 0 1;"
    xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="br.com.poderfinanceiro.app.controller.AjudaChatController">

    <HBox alignment="CENTER_LEFT"
        style="-fx-background-color: #FFFFFF; -fx-padding: 16 20; -fx-border-color: #EEEEEE; -fx-border-width: 0 0 1 0;">
        <VBox spacing="2">
            <Label text="Poder Financeiro Gemini IA"
                style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #212121; -fx-font-family: 'Segoe UI', 'Helvetica Neue', sans-serif;" />
            <Label text="● Analista Especialista Ativo"
                style="-fx-font-size: 13px; -fx-text-fill: #1B5E20; -fx-font-weight: bold; -fx-font-family: 'Segoe UI', sans-serif;" />
        </VBox>
        <Pane HBox.hgrow="ALWAYS" />
        <Button text="✕" onAction="#fecharPainel"
            style="-fx-background-color: transparent; -fx-font-size: 18px; -fx-cursor: hand; -fx-text-fill: #9E9E9E; -fx-font-weight: bold; -fx-padding: 5;" />
    </HBox>

    <ScrollPane fx:id="scrollChat" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
        VBox.vgrow="ALWAYS"
        style="-fx-background: #efeae2; -fx-background-color: #efeae2; -fx-border-color: transparent;">
        <VBox fx:id="containerMensagens" spacing="14"
            style="-fx-padding: 20 16; -fx-background-color: #efeae2;">

            <VBox alignment="CENTER_LEFT">
                <Label
                    text="Olá! Sou o seu analista de crédito sênior. Como posso ajudar com margens, regras bancárias ou portabilidade hoje?"
                    wrapText="true"
                    style="-fx-background-color: #FFFFFF; -fx-text-fill: #000000; -fx-padding: 10 14; -fx-background-radius: 12 12 12 0; -fx-font-size: 15px; -fx-max-width: 320; -fx-font-family: 'Segoe UI', sans-serif; -fx-line-spacing: 2.5px; -fx-effect: dropshadow(one-pass-box, rgba(0,0,0,0.06), 2, 0, 0, 1);" />
            </VBox>

        </VBox>
    </ScrollPane>

    <VBox
        style="-fx-background-color: #F0F2F5; -fx-padding: 14 16; -fx-border-color: #DDDDDD; -fx-border-width: 1 0 0 0;">
        <HBox spacing="12" alignment="CENTER">
            <TextField fx:id="txtMensagem" promptText="Digite sua dúvida operacional..."
                HBox.hgrow="ALWAYS" onAction="#enviarMensagem"
                style="-fx-background-color: #FFFFFF; -fx-background-radius: 22; -fx-padding: 12 18; -fx-font-size: 15px; -fx-text-fill: #000000; -fx-font-family: 'Segoe UI', sans-serif;" />
            <Button text="➤" onAction="#enviarMensagem"
                style="-fx-background-color: #00a884; -fx-text-fill: white; -fx-background-radius: 22; -fx-min-width: 44; -fx-min-height: 44; -fx-max-width: 44; -fx-max-height: 44; -fx-font-size: 16px; -fx-cursor: hand;" />
        </HBox>
    </VBox>
</VBox>